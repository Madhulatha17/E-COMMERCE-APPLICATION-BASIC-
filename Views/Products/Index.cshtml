@model IEnumerable<ECommerceApp.Models.Product>

<h2>Products</h2>

@foreach(var item in Model)
{
    <div>
        <h3>@item.Name</h3>

        <p>@item.Description</p>

        <p>₹@item.Price</p>

        <a href="/Cart/Add?id=@item.Id
        &name=@item.Name
        &price=@item.Price">
        Add To Cart
        </a>
    </div>

    <hr />
}
